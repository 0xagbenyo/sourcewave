# ERPNext Configuration
EXPO_PUBLIC_ERPNEXT_URL=http://localhost:8000
EXPO_PUBLIC_ERPNEXT_API_KEY=your_api_key_here
EXPO_PUBLIC_ERPNEXT_API_SECRET=your_api_secret_here
EXPO_PUBLIC_ERPNEXT_DEFAULT_COMPANY=Glamora Ltd

# Native Raven UI also calls: raven.api.workspaces.fetch_workspace_members, raven.api.raven_channel.create_direct_message_channel
# Uses raven.api.raven_channel.get_channels (same as web). Optional default workspace name:
# EXPO_PUBLIC_RAVEN_WORKSPACE=Sourcewave

# Frappe User.name used to find Raven Channel Member rows (when different from app login email)
# EXPO_PUBLIC_RAVEN_USER=user@example.com

# Optional Raven web URL (e.g. open-in-browser from chat header)
# EXPO_PUBLIC_RAVEN_URL=https://your-site.frappe.cloud/raven/Raven/

# App Configuration
EXPO_PUBLIC_APP_NAME=Glamora
EXPO_PUBLIC_APP_VERSION=1.0.0
EXPO_PUBLIC_CURRENCY=GH₵
EXPO_PUBLIC_COUNTRY_CODE=GH

# Feature Flags
EXPO_PUBLIC_ENABLE_MOCK_DATA=true
EXPO_PUBLIC_DEBUG_MODE=false
