# ERPNext Configuration
EXPO_PUBLIC_ERPNEXT_URL=https://sourcewave.frappe.cloud
# Used by App.tsx (aliases EXPO_PUBLIC_ERPNEXT_API_* also supported)
EXPO_PUBLIC_API_KEY=your_api_key_here
EXPO_PUBLIC_API_SECRET=your_api_secret_here
EXPO_PUBLIC_ERPNEXT_DEFAULT_COMPANY=Glamora Ltd

# Native Raven UI also calls: raven.api.workspaces.fetch_workspace_members, raven.api.raven_channel.create_direct_message_channel
# Uses raven.api.raven_channel.get_channels (same as web). Optional default workspace name:
# Raven workspace document name (e.g. d4a650rmcq) or display name (e.g. Sourcewave).
# EXPO_PUBLIC_RAVEN_WORKSPACE=Sourcewave

# Optional: whitelisted Frappe method path to set Raven User.custom_customer when the API user cannot Write Raven User.
# The app POSTs JSON kwargs; implement one signature, e.g. (raven_user, customer) both strings — Customer `name` as value.
# Server example (Custom Script / your app — run as a user who may update Raven User, or use db.set_value + Administrator key):
#   @frappe.whitelist()
#   def set_raven_user_customer(raven_user=None, customer=None):
#       if not raven_user or not customer: frappe.throw("raven_user and customer required")
#       frappe.db.set_value("Raven User", raven_user, "custom_customer", customer)
#       frappe.db.commit()
#       return {"ok": True}
# EXPO_PUBLIC_RAVEN_USER_SET_CUSTOMER_METHOD=my_custom_app.api.raven.set_raven_user_customer

# Frappe User.name used to find Raven Channel Member rows (when different from app login email)
# EXPO_PUBLIC_RAVEN_USER=user@example.com

# Optional Raven web URL (e.g. open-in-browser from chat header)
# EXPO_PUBLIC_RAVEN_URL=https://your-site.frappe.cloud/raven/Raven/

# Optional custom Link field names (defaults shown):
# EXPO_PUBLIC_ERPNEXT_SQ_CUSTOMER_LINK_FIELD=custom_customer
# EXPO_PUBLIC_ERPNEXT_SQ_ORDER_LINK_FIELD=custom_order
# EXPO_PUBLIC_ERPNEXT_SI_QUOTATION_LINK_FIELD=custom_quotation
# EXPO_PUBLIC_ERPNEXT_SI_SUPPLIER_LINK_FIELD=custom_supplier
# EXPO_PUBLIC_ERPNEXT_SO_QUOTATION_LINK_FIELD=custom_quotation
# EXPO_PUBLIC_ERPNEXT_SO_SUPPLIER_LINK_FIELD=custom_supplier
# Mandatory "Series Copy" on Sales Order (defaults to naming_series when saving drafts)
# EXPO_PUBLIC_ERPNEXT_SO_SERIES_COPY_FIELD=custom_series_copy
# EXPO_PUBLIC_ERPNEXT_SO_SERIES_COPY_DEFAULT=SAL-ORD-.YYYY.-

# Invoice Paystack — direct Paystack checkout (same keys as subscriptions); creates Payment Entry on success
EXPO_PUBLIC_PAYSTACK_SECRET_KEY=sk_test_...
EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_...
# Optional: map Paystack channel → ERPNext Mode of Payment after payment
# EXPO_PUBLIC_ERPNEXT_PAYSTACK_MODE_OF_PAYMENT=Paystack

# Legacy ERPNext Payment Request gateway (no longer used for in-app invoice pay):
# EXPO_PUBLIC_ERPNEXT_PAYSTACK_GATEWAY=Paystack

# Contact us — Raven support channel when the user is a member, else DM with support user
# EXPO_PUBLIC_SOURCEWAVE_SUPPORT_RAVEN_CHANNEL=0i3gsqc8ld
# EXPO_PUBLIC_SOURCEWAVE_SUPPORT_RAVEN_WORKSPACE=Sourcewave
# EXPO_PUBLIC_SOURCEWAVE_SUPPORT_RAVEN_USER=Administrator

# App Configuration
EXPO_PUBLIC_APP_NAME=Glamora
EXPO_PUBLIC_APP_VERSION=1.0.0
EXPO_PUBLIC_CURRENCY=GH₵
EXPO_PUBLIC_COUNTRY_CODE=GH

# Feature Flags
EXPO_PUBLIC_ENABLE_MOCK_DATA=true
EXPO_PUBLIC_DEBUG_MODE=false
