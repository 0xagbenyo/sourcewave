# ERPNext Configuration
EXPO_PUBLIC_ERPNEXT_URL=http://localhost:8000
EXPO_PUBLIC_ERPNEXT_API_KEY=your_api_key_here
EXPO_PUBLIC_ERPNEXT_API_SECRET=your_api_secret_here
EXPO_PUBLIC_ERPNEXT_DEFAULT_COMPANY=Glamora Ltd

# Native Raven UI also calls: raven.api.workspaces.fetch_workspace_members, raven.api.raven_channel.create_direct_message_channel
# Uses raven.api.raven_channel.get_channels (same as web). Optional default workspace name:
# EXPO_PUBLIC_RAVEN_WORKSPACE=Sourcewave

# Optional: whitelisted Frappe method path to set Raven User.custom_customer when the API user cannot Write Raven User.
# The app POSTs JSON kwargs; implement one signature, e.g. (raven_user, customer) both strings — Customer `name` as value.
# Server example (Custom Script / your app — run as a user who may update Raven User, or use db.set_value + Administrator key):
#   @frappe.whitelist()
#   def set_raven_user_customer(raven_user=None, customer=None):
#       if not raven_user or not customer: frappe.throw("raven_user and customer required")
#       frappe.db.set_value("Raven User", raven_user, "custom_customer", customer)
#       frappe.db.commit()
#       return {"ok": True}
# EXPO_PUBLIC_RAVEN_USER_SET_CUSTOMER_METHOD=my_custom_app.api.raven.set_raven_user_customer

# Frappe User.name used to find Raven Channel Member rows (when different from app login email)
# EXPO_PUBLIC_RAVEN_USER=user@example.com

# Optional Raven web URL (e.g. open-in-browser from chat header)
# EXPO_PUBLIC_RAVEN_URL=https://your-site.frappe.cloud/raven/Raven/

# App Configuration
EXPO_PUBLIC_APP_NAME=Glamora
EXPO_PUBLIC_APP_VERSION=1.0.0
EXPO_PUBLIC_CURRENCY=GH₵
EXPO_PUBLIC_COUNTRY_CODE=GH

# Feature Flags
EXPO_PUBLIC_ENABLE_MOCK_DATA=true
EXPO_PUBLIC_DEBUG_MODE=false

# Paystack Payment Gateway Configuration
# Get these from https://dashboard.paystack.com/settings/developers
# IMPORTANT: Never commit real API keys to version control!
EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_your_public_key_here
EXPO_PUBLIC_PAYSTACK_SECRET_KEY=sk_live_your_secret_key_here
