{
  "expo": {
    "name": "SOURCEWAVE",
    "slug": "SourcewaveApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/sourcewave logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "sourcewave",
    "splash": {
      "image": "./src/assets/images/sourcewave logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "CFBundleDisplayName": "SOURCEWAVE"
      }
    },
    "android": {
      "package": "com.agbenyo.sourcewaveapp",
      "label": "SOURCEWAVE",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/sourcewave logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow SOURCEWAVE to access your photos to attach images and set your profile picture.",
          "cameraPermission": "Allow SOURCEWAVE to use the camera for your profile picture."
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "7e8bf2c3-0af7-409f-9ad4-0a8149016f78"
      }
    },
    "owner": "agbenyo"
  }
}
